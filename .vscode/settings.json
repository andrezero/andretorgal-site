{
  "spellright.language": ["en", "es", "de", "fr", "it", "pt", "uk", "ar"],
  "spellright.documentTypes": ["plaintext", "markdown", "javascript", "typescript", "html", "css"],
  "spellright.notificationClass": "warning",
  "editor.tabSize": 4,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "explorer.excludeGitIgnore": true,
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/coverage": true,
    "**/dist": true,
    "**/.cache": true,
    "**/.yarn": true
  },
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#941614",
    "titleBar.activeForeground": "#f6f8f9",
    "sideBar.background": "#202427",
    "sideBar.foreground": "#c7cacc"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.options": {
    "extensions": [".js", ".ts"]
  },
  "eslint.validate": ["javascript", "html", "typescript"],
  "editor.minimap.maxColumn": 400,
  "editor.scrollbar.verticalScrollbarSize": 20
}
