      "name": "Build",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/build/site.js"
    },

    {
      "type": "node",
      "request": "launch",
      "name": "Locale",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/build/locale.js"
