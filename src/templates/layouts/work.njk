      {{ page.sections['education-programmes'].html | safe }}
    </div>
    <div class="formatted-content">
      {{ page.sections['students-and-juniors'].html | safe }}
    </div>

    {{ get_in_touch() }}
  </div>

  <div class="approach">
    <div class="formatted-content">
      {{ page.sections.approach.html | safe }}
    </div>

    {{ get_in_touch() }}

    <div class="formatted-content">
    {% include 'partials/content/languages.njk' %}
    </div>
  </div>
{% endblock %}
