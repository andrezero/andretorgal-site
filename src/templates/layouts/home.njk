{% from "components/layouts/hero.njk" import hero %}
{% from "components/action/learn_more.njk" import learn_more %}

{% extends "layouts/private/base-page.njk" %}

{% block mainLayoutName %}home{% endblock%}
{% block mainContentClass %}container-centered{% endblock%}

{% block before %}
  {{
      hero({
          title: page.sections.hero.title,
          html: page.sections.hero.html
      })
  }}
{% endblock %}

{% block content %}
  <div class="formatted-content">
    {{ page.sections.collab.html | safe }}
  </div>

  {{ learn_more({ url:  iurl("/work", page.lang), label: t('site.common-exp.collaborate') }) }}

  <div class="formatted-content">
    {{ page.sections.music.html | safe }}
  </div>

  {% set linkLabel = t('/work') %}
  {{ learn_more({ url:  iurl("/music", page.lang), label: t('site.common-exp.listen') }) }}

  <div class="formatted-content">
    {{ page.html | safe }}
  </div>
{% endblock %}

