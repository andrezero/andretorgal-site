    <ul>
      {% for item in site.map %}
        {% if item.level <= 2 and not item.data.nav.hide %}
          {% if  item.lang == page.lang %}
            <li>
              {% set isCurrent = item.url === page.url if item.isRoot else page.url.startsWith(item.url) %}
              <a
                href="{{ item.url }}"
                {% if isCurrent %}
                aria-current="page"
                class="current"
                {% endif %}
              >
                {{ item.title }}
              </a>
            </li>
          {% endif %}
        {% endif %}
      {% endfor %}
    </ul>
  </nav>

